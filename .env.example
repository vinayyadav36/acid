# =============================================================================
# ACID - Advanced Database Interface System
# =============================================================================
# Configuration file - Copy to .env and update values
# 
# HOW TO USE:
# 1. Copy this file to .env
# 2. Update values with your configuration
# 3. Start the server
# =============================================================================

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=8080
ENVIRONMENT=development  # development, staging, production

# =============================================================================
# DATABASE CONFIGURATION (Required)
# =============================================================================
# Format: postgres://username:password@host:port/database
# Example: postgres://myuser:mypassword@localhost:5432/mydb
DATABASE_URL=postgres://lsd:password@localhost:5432/lsd
ADMIN_DB_STORAGE_PATH=./databases/admin_storage
SEARCH_BACKEND=clickhouse
ELASTICSEARCH_URL=
OPENSEARCH_URL=
ANALYTICS_LAKE=hdfs
ANALYTICS_LAKE_URI=
SPARK_MASTER_URL=

# Read replica (optional) - for scaling reads
DATABASE_REPLICA_URL=postgres://lsd:password@replica:5432/lsd

# =============================================================================
# AUTHENTICATION
# =============================================================================
# JWT Secret - MUST change in production!
# Generate new secret: openssl rand -base64 32
JWT_SECRET=acid-jwt-secret-key-change-in-production

# Token expiry times (Go duration format)
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=168h  # 7 days

# =============================================================================
# REDIS CACHING (Optional but recommended)
# =============================================================================
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# CLICKHOUSE SEARCH ENGINE (Optional but recommended for fast search)
# =============================================================================
CLICKHOUSE_ADDR=localhost:9000
CLICKHOUSE_DB=acid
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# =============================================================================
# RATE LIMITING
# =============================================================================
# Requests per minute
RATE_LIMIT_ANONYMOUS=100
RATE_LIMIT_AUTHENTICATED=1000
RATE_LIMIT_AI_AGENT=5000

# =============================================================================
# CDC CONFIGURATION (Data sync to ClickHouse)
# =============================================================================
ENABLE_CDC=true
CDC_BATCH_SIZE=10000
CDC_SYNC_INTERVAL=30s

# =============================================================================
# INTELLIGENCE SEARCH (Entity/Database search)
# =============================================================================
ENABLE_DB_SEARCH=true

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info  # debug, info, warn, error
LOG_FORMAT=json  # json, text
