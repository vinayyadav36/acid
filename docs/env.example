# L.S.D API Configuration Example
# Copy to .env and update values

# ═══════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ═══════════════════════════════════════════════════════════

PORT=8080
ENVIRONMENT=development  # development, staging, production

# ═══════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════

DATABASE_URL=postgres://lsd:password@localhost:5432/lsd

# Read replica (optional)
DATABASE_REPLICA_URL=postgres://lsd:password@replica:5432/lsd

# ═══════════════════════════════════════════════════════════
# AUTHENTICATION
# ═══════════════════════════════════════════════════════════

# JWT Secret - MUST be changed in production!
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secure-jwt-secret-min-32-characters-long

# Token expiry times (Go duration format)
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=168h  # 7 days

# ═══════════════════════════════════════════════════════════
# REDIS CONFIGURATION (Optional - for caching)
# ═══════════════════════════════════════════════════════════

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ═══════════════════════════════════════════════════════════
# CLICKHOUSE CONFIGURATION (Optional - for search)
# ═══════════════════════════════════════════════════════════

CLICKHOUSE_ADDR=localhost:9000
CLICKHOUSE_DB=lsd
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ═══════════════════════════════════════════════════════════
# RATE LIMITING
# ═══════════════════════════════════════════════════════════

# Requests per minute limits
RATE_LIMIT_ANONYMOUS=100
RATE_LIMIT_AUTHENTICATED=1000
RATE_LIMIT_AI_AGENT=5000

# ═══════════════════════════════════════════════════════════
# CDC CONFIGURATION
# ═══════════════════════════════════════════════════════════

ENABLE_CDC=true
CDC_BATCH_SIZE=10000
CDC_SYNC_INTERVAL=30s

# ═══════════════════════════════════════════════════════════
# DB-SEARCH & INTELLIGENCE FEATURES
# #feature-flag: set true to enable /api/admin/db-search,
#   /api/smart-search, /api/entities, /api/cases, etc.
# Set false to deploy the binary without exposing these routes.
# ═══════════════════════════════════════════════════════════

# Master toggle for all intelligence/search features
ENABLE_DB_SEARCH=true

# ═══════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════

LOG_LEVEL=info  # debug, info, warn, error
LOG_FORMAT=json  # json, text
